# Copy to .env.local for local development (never commit .env.local).
# Use a separate Firebase project per environment per ROADMAP.md Phase 0
# (nourishos-dev / nourishos-staging / nourishos-prod).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional
VITE_FIREBASE_MEASUREMENT_ID=

# Set to "true" to connect to local Firebase Emulator Suite instead of live project
VITE_USE_FIREBASE_EMULATOR=false
